# ─── Flask ────────────────────────────────────────────────────────────────────
FLASK_ENV=development
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-32-char-string

# ─── Base de datos ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://semimus:semimus_secret@localhost:5432/semimus
POSTGRES_DB=semimus
POSTGRES_USER=semimus
POSTGRES_PASSWORD=semimus_secret

# ─── Audio ────────────────────────────────────────────────────────────────────
AUDIO_STORAGE_PATH=./audio_storage
MAX_AUDIO_SIZE_MB=50

# ─── Email (opcional) ─────────────────────────────────────────────────────────
# Para Gmail: crea una App Password en myaccount.google.com/apppasswords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@semimus.app
