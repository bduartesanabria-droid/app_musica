# ============================================================
# SEMIMUS — Variables de entorno
# Copia como .env y completa los valores ANTES de levantar Docker
# ============================================================

# ── Entorno ─────────────────────────────────────────────────
FLASK_ENV=production

# ── Seguridad (OBLIGATORIO cambiar en producción) ───────────
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-en-produccion-min-32-chars
JWT_SECRET_KEY=cambia-esto-en-produccion-jwt-min-32-chars

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_DB=semimus
POSTGRES_USER=semimus
POSTGRES_PASSWORD=semimus_password_segura_123!
# La DATABASE_URL se construye automáticamente en docker-compose
# Para desarrollo local sin Docker:
# DATABASE_URL=postgresql://semimus:semimus_password_segura_123!@localhost:5432/semimus

# ── Redis ───────────────────────────────────────────────────
# Se configura automáticamente en Docker

# ── Almacenamiento de audio ─────────────────────────────────
# Rutas donde Docker monta los volúmenes persistentes en el HOST
POSTGRES_DATA_PATH=./data/postgres
REDIS_DATA_PATH=./data/redis
AUDIO_DATA_PATH=./data/audio
MAX_AUDIO_SIZE_MB=50

# ── URLs y CORS ─────────────────────────────────────────────
FRONTEND_URL=https://tu-dominio.com
CORS_ORIGINS=https://tu-dominio.com
VITE_API_URL=/api

# ── Gunicorn ────────────────────────────────────────────────
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120

# ── Correo electrónico ──────────────────────────────────────
# Para Gmail: crea una App Password en myaccount.google.com/apppasswords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu@gmail.com
MAIL_PASSWORD=tu-app-password-de-16-digitos
MAIL_DEFAULT_SENDER=SEMIMUS <noreply@tu-dominio.com>
